    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "\n",
    "# --- Config -------------------------------------------------------------------\n",
    "\n",
    "COLORS = {\n",
    "    \"Facil\":         \"#4C9BE8\",  # blue\n",
    "    \"Medio\":         \"#F4A261\",  # orange\n",
    "    \"Dificil\":       \"#2A9D8F\",  # teal\n",
    "    \"Decision Tree\": \"#E76F51\",  # red\n",
    "}\n",
    "\n",
    "LABELS = {\n",
    "    \"Facil\":         \"MCTS Easy\\n(matrices)\",\n",
    "    \"Medio\":         \"MCTS Medium\\n(flat tuples)\",\n",
    "    \"Dificil\":       \"MCTS Hard\\n(bitboard)\",\n",
    "    \"Decision Tree\": \"Decision Tree\\n(ID3/iris)\",\n",
    "}\n",
    "\n",
    "AGENTS = [\"Facil\", \"Medio\", \"Dificil\", \"Decision Tree\"]\n",
    "\n",
    "# --- Load & process data ------------------------------------------------------\n",
    "\n",
    "df = pd.read_csv(\"benchmark_resultados.csv\")\n",
    "\n",
    "# win_matrix[A][B] = win rate of A against B\n",
    "win_matrix  = pd.DataFrame(0.0, index=AGENTS, columns=AGENTS)\n",
    "total_wins  = {a: 0 for a in AGENTS}\n",
    "total_games = {a: 0 for a in AGENTS}\n",
    "\n",
    "for _, row in df.iterrows():\n",
    "    a1, a2, g = row[\"agente1\"], row[\"agente2\"], row[\"n_jogos\"]\n",
    "    w1, w2    = row[\"vitorias1\"], row[\"vitorias2\"]\n",
    "\n",
    "    win_matrix.loc[a1, a2] = w1 / g\n",
    "    win_matrix.loc[a2, a1] = w2 / g\n",
    "\n",
    "    total_wins[a1]  += w1;  total_games[a1] += g\n",
    "    total_wins[a2]  += w2;  total_games[a2] += g\n",
    "\n",
    "overall_wr = {a: total_wins[a] / total_games[a] for a in AGENTS}"
   ]
